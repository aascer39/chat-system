# ============================================
# Chat System — Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=chat_system
DB_USERNAME=postgres
DB_PASSWORD=change_me

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# JWT
JWT_SECRET=replace-with-your-256-bit-secret-key
JWT_EXPIRATION=86400000

# Server
SERVER_PORT=8080
